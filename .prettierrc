{
	"useTabs": true,
	"trailingComma": "none",
	"printWidth": 120,
	"plugins": ["prettier-plugin-svelte", "@trivago/prettier-plugin-sort-imports"],
	"overrides": [
		{
			"files": "*.svelte",
			"options": {
				"parser": "svelte"
			}
		}
	],
	"importOrder": [
		"<THIRD_PARTY_MODULES>",
		"<BUILTIN_MODULES>",
		"^\\$lib/(?!components)(.*)$",
		"^[./]",
		"^(?:\\$lib/components/ui/.*|@lucide/svelte/.*)$"
	],
	"importOrderSeparation": true,
	"importOrderSortSpecifiers": true
}
